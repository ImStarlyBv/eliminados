---
interface Props {
  date: string;
}
const { date } = Astro.props;

const navItems = [
  { label: 'Inicio', href: '/', active: true },
  { label: 'Farándula', href: '/farandula/' },
  { label: 'Reality', href: '/reality/' },
  { label: 'Música', href: '/musica/' },
  { label: 'Deportes', href: '/deportes/' },
  { label: 'Viral', href: '/viral/' },
  { label: 'TV', href: '/tv/' },
  { label: 'Opinión', href: '/opinion/' },
];
---

<!-- Top Red Strip -->
<div style="
  background: var(--color-primary);
  color: white;
  padding: 0.375rem 1rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.625rem;
  font-family: var(--font-headline);
  text-transform: uppercase;
  letter-spacing: 0.15em;
  position: sticky;
  top: 0;
  z-index: 50;
">
  <div style="display: flex; gap: 1rem; align-items: center;">
    <span>{date}</span>
    <span style="display: none;" class="desktop-only-inline">Santo Domingo 31°C</span>
  </div>
  <div style="display: flex; gap: 1rem; align-items: center;">
    <span class="material-symbols-outlined" style="font-size: 14px;">public</span>
    <span class="material-symbols-outlined" style="font-size: 14px;">wb_sunny</span>
    <span class="material-symbols-outlined" style="font-size: 14px;">calendar_today</span>
  </div>
</div>

<!-- Main Header -->
<header id="main-header" style="
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  position: sticky;
  top: 30px;
  z-index: 40;
  box-shadow: 0 20px 40px rgba(49, 46, 41, 0.06);
">
  <div class="container-site" style="
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 1rem;
    padding-bottom: 1rem;
  ">
    <!-- Top row: Logo + Search + Subscribe -->
    <div style="
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
      margin-bottom: 1rem;
    ">
      <a href="/" style="text-decoration: none;">
        <h1 class="font-headline" style="
          font-size: 2.25rem;
          font-weight: 900;
          font-style: italic;
          color: var(--color-primary);
          line-height: 1;
          text-transform: uppercase;
          letter-spacing: -0.05em;
          white-space: nowrap;
        ">
          ELIMINADOS
        </h1>
      </a>

      <!-- Search (desktop) -->
      <div class="search-desktop" style="
        flex: 1;
        max-width: 28rem;
        position: relative;
      ">
        <input
          type="text"
          placeholder="Buscar noticias..."
          style="
            width: 100%;
            background: var(--color-surface-container-highest);
            border: none;
            border-radius: 9999px;
            padding: 0.625rem 1.5rem;
            font-size: 0.875rem;
            outline: none;
          "
        />
        <button style="
          position: absolute;
          right: 1rem;
          top: 50%;
          transform: translateY(-50%);
          background: none;
          border: none;
          cursor: pointer;
          color: var(--color-on-surface-variant);
        ">
          <span class="material-symbols-outlined">search</span>
        </button>
      </div>

      <a href="#newsletter" style="
        background: var(--color-secondary-fixed);
        color: #473000;
        font-family: var(--font-headline);
        font-weight: 900;
        padding: 0.75rem 2rem;
        border-radius: 0.75rem;
        text-transform: uppercase;
        letter-spacing: -0.03em;
        font-size: 0.875rem;
        text-decoration: none;
        transition: transform 0.15s, background 0.2s;
        white-space: nowrap;
      ">
        SUSCRÍBETE
      </a>
    </div>

    <!-- Navigation -->
    <nav style="
      width: 100%;
      border-top: 1px solid var(--color-surface-container-highest);
      padding-top: 1rem;
    ">
      <ul id="main-nav" style="
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5rem 2rem;
        list-style: none;
        text-transform: uppercase;
        font-size: 0.6875rem;
        font-weight: 900;
        font-family: var(--font-headline);
        letter-spacing: 0.15em;
      ">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              style={`
                color: ${item.active ? 'var(--color-primary)' : '#52525b'};
                text-decoration: none;
                ${item.active ? 'border-bottom: 4px solid var(--color-secondary-fixed); padding-bottom: 0.25rem;' : ''}
                transition: color 0.2s;
              `}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
  <div style="background: #f4f4f5; height: 1px; width: 100%;"></div>
</header>

<!-- Breaking News Ticker -->
<div style="
  background: rgba(255, 117, 118, 0.15);
  padding: 0.5rem 0;
  overflow: hidden;
  white-space: nowrap;
  margin-bottom: 2rem;
">
  <div class="animate-marquee" style="
    display: flex;
    gap: 3rem;
    padding: 0 1rem;
  ">
    <span style="color: var(--color-primary); font-weight: 900; text-transform: uppercase; font-size: 0.75rem; letter-spacing: -0.03em; font-style: italic;">
      ÚLTIMO MINUTO: Las eliminaciones que sacuden el entretenimiento dominicano
    </span>
    <span style="color: var(--color-primary); font-weight: 900; text-transform: uppercase; font-size: 0.75rem; letter-spacing: -0.03em; font-style: italic;">
      EXCLUSIVA: Nuevos detalles sobre los eliminados de la temporada
    </span>
    <span style="color: var(--color-primary); font-weight: 900; text-transform: uppercase; font-size: 0.75rem; letter-spacing: -0.03em; font-style: italic;">
      VIRAL: La reacción que nadie esperaba después de la eliminación
    </span>
    <!-- Duplicate for seamless loop -->
    <span style="color: var(--color-primary); font-weight: 900; text-transform: uppercase; font-size: 0.75rem; letter-spacing: -0.03em; font-style: italic;">
      ÚLTIMO MINUTO: Las eliminaciones que sacuden el entretenimiento dominicano
    </span>
    <span style="color: var(--color-primary); font-weight: 900; text-transform: uppercase; font-size: 0.75rem; letter-spacing: -0.03em; font-style: italic;">
      EXCLUSIVA: Nuevos detalles sobre los eliminados de la temporada
    </span>
  </div>
</div>

<style>
  @media (max-width: 767px) {
    .search-desktop { display: none !important; }
  }
  @media (min-width: 768px) {
    .desktop-only-inline { display: inline !important; }
  }
</style>
