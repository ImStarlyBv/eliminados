---
interface TrendingItem {
  rank: string;
  title: string;
  category: string;
  href: string;
}

interface Props {
  items: TrendingItem[];
}

const { items } = Astro.props;
---

<aside>
  <div style="
    background: var(--color-surface-container-low);
    padding: 2rem;
    border-radius: 2px;
  ">
    <h3 class="font-headline" style="
      font-size: 1.5rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -0.05em;
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    ">
      MÁS LEÍDAS
      <span style="
        flex: 1;
        height: 0.25rem;
        background: var(--color-secondary-fixed);
      "></span>
    </h3>

    <div style="display: flex; flex-direction: column; gap: 2rem;">
      {items.map((item, i) => (
        <a href={item.href} style={`
          display: flex;
          gap: 1rem;
          cursor: pointer;
          text-decoration: none;
          color: inherit;
          ${i > 0 ? `border-top: 1px solid var(--color-surface-container-highest); padding-top: 1.5rem;` : ''}
        `}>
          <span class="font-headline" style="
            font-size: 2.25rem;
            font-weight: 900;
            color: var(--color-secondary-fixed-dim);
            font-style: italic;
            line-height: 1;
            flex-shrink: 0;
          ">
            {item.rank}
          </span>
          <div>
            <h4 class="font-headline" style="
              font-weight: 900;
              font-size: 0.875rem;
              text-transform: uppercase;
              line-height: 1.3;
              transition: color 0.2s;
            ">
              {item.title}
            </h4>
            <p style="
              font-size: 0.625rem;
              color: var(--color-on-surface-variant);
              margin-top: 0.25rem;
              text-transform: uppercase;
              font-weight: 700;
              letter-spacing: 0.15em;
            ">
              {item.category}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</aside>
