---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildJsonLd } from '@/lib/seo';

const { slug } = Astro.params;
const siteUrl = import.meta.env.SITE || 'https://eliminados.online';

// Display name: capitalize and restore spaces
const tagName = (slug || '')
  .replace(/-/g, ' ')
  .replace(/\b\w/g, (c) => c.toUpperCase());

const seo = {
  title: `#${tagName} — ELIMINADOS | Noticias de Entretenimiento`,
  description: `Todas las noticias etiquetadas con #${tagName}. Lo más reciente y relevante en ELIMINADOS.`,
  canonicalUrl: `${siteUrl}/tag/${slug}/`,
  type: 'website' as const,
};

const jsonLd = buildJsonLd({
  type: 'WebSite',
  title: seo.title,
  description: seo.description,
  url: seo.canonicalUrl,
  siteName: 'ELIMINADOS',
  siteUrl,
  breadcrumbs: [
    { name: 'Inicio', url: siteUrl },
    { name: 'Tags', url: `${siteUrl}/tag/` },
    { name: `#${tagName}`, url: `${siteUrl}/tag/${slug}/` },
  ],
});

// TODO: Query DB for articles with this tag
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <main class="container-site" style="margin-bottom: 5rem; padding-top: 2rem;">

    <!-- Breadcrumb -->
    <nav style="
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      font-size: 0.625rem;
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--color-on-surface-variant);
    ">
      <a href="/" style="text-decoration: none; color: inherit;">INICIO</a>
      <span class="material-symbols-outlined" style="font-size: 10px;">chevron_right</span>
      <span style="color: var(--color-on-surface);">#{tagName.toUpperCase()}</span>
    </nav>

    <!-- Tag Header -->
    <div style="
      text-align: center;
      padding: 3rem 1rem;
      margin-bottom: 3rem;
      border-bottom: 1px solid var(--color-surface-container-highest);
    ">
      <span style="
        display: inline-block;
        background: var(--color-primary);
        color: white;
        font-family: var(--font-headline);
        font-weight: 900;
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        padding: 0.75rem 2rem;
        text-transform: uppercase;
        letter-spacing: -0.03em;
        margin-bottom: 1rem;
      ">
        #{tagName}
      </span>
      <p style="
        color: var(--color-on-surface-variant);
        max-width: 32rem;
        margin: 0 auto;
        font-size: 1rem;
      ">
        Todos los artículos etiquetados con <strong>#{tagName}</strong>
      </p>
    </div>

    <!-- Empty state -->
    <div style="
      text-align: center;
      padding: 3rem 1rem;
      border: 2px dashed var(--color-outline-variant);
      border-radius: 0.5rem;
      color: var(--color-on-surface-variant);
    ">
      <span class="material-symbols-outlined" style="font-size: 3rem; opacity: 0.4;">label</span>
      <p class="font-headline" style="font-weight: 700; margin-top: 1rem;">
        Artículos con este tag próximamente
      </p>
      <p style="font-size: 0.875rem; margin-top: 0.5rem;">
        Los artículos publicados con este tag aparecerán aquí automáticamente.
      </p>
    </div>

  </main>
</BaseLayout>
