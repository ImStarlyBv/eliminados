---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { buildJsonLd } from '@/lib/seo';
import { db } from '@/lib/db';
import { DEFAULT_IMAGE } from '@/lib/defaults';
import { articles, tags, articleTags, categories } from '@/db/schema';
import { eq, and, desc } from 'drizzle-orm';

const { slug } = Astro.params;
const tagSlug = slug || '';
const siteUrl = import.meta.env.SITE || 'https://eliminados.online';

const [tag] = await db
  .select({ id: tags.id, slug: tags.slug, name: tags.name })
  .from(tags)
  .where(eq(tags.slug, tagSlug))
  .limit(1);

// Unknown tag → real 404. Prevents indexing of soft-404 / infinite empty
// /tag/<anything> URLs.
if (!tag) {
  return new Response('Not Found', { status: 404 });
}

const tagName = tag.name;

const rows = await db
  .select({
    id: articles.id,
    slug: articles.slug,
    title: articles.title,
    metaDescription: articles.metaDescription,
    ogImage: articles.ogImage,
    publishedAt: articles.publishedAt,
    categoryName: categories.name,
  })
  .from(articleTags)
  .innerJoin(articles, eq(articleTags.articleId, articles.id))
  .leftJoin(categories, eq(articles.categoryId, categories.id))
  .where(and(eq(articleTags.tagId, tag.id), eq(articles.status, 'published')))
  .orderBy(desc(articles.publishedAt))
  .limit(48);

const seo = {
  title: `#${tagName} — ELIMINADOS | Noticias de Entretenimiento`,
  description: `Todas las noticias etiquetadas con #${tagName}. Lo más reciente y relevante en ELIMINADOS.`,
  canonicalUrl: `${siteUrl}/tag/${tagSlug}/`,
  type: 'website' as const,
  // Tag exists but has no published articles yet → keep it out of the index
  // until it has real content (avoids thin/empty section pages ranking).
  noindex: rows.length === 0,
};

const jsonLd = buildJsonLd({
  type: 'WebSite',
  title: seo.title,
  description: seo.description,
  url: seo.canonicalUrl,
  siteName: 'ELIMINADOS',
  siteUrl,
  breadcrumbs: [
    { name: 'Inicio', url: siteUrl },
    { name: `#${tagName}`, url: `${siteUrl}/tag/${tagSlug}/` },
  ],
});

const cards = rows.map((a) => ({
  title: a.title,
  excerpt: a.metaDescription,
  image: a.ogImage || DEFAULT_IMAGE,
  imageAlt: a.title,
  category: (a.categoryName || 'NOTICIAS').toUpperCase(),
  href: `/${a.slug}`,
}));
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <main class="container-site" style="margin-bottom: 5rem; padding-top: 2rem;">

    <!-- Breadcrumb -->
    <nav style="
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      font-size: 0.625rem;
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--color-on-surface-variant);
    ">
      <a href="/" style="text-decoration: none; color: inherit;">INICIO</a>
      <span class="material-symbols-outlined" style="font-size: 10px;">chevron_right</span>
      <span style="color: var(--color-on-surface);">#{tagName.toUpperCase()}</span>
    </nav>

    <!-- Tag Header -->
    <div style="
      text-align: center;
      padding: 3rem 1rem;
      margin-bottom: 3rem;
      border-bottom: 1px solid var(--color-surface-container-highest);
    ">
      <span style="
        display: inline-block;
        background: var(--color-primary);
        color: white;
        font-family: var(--font-headline);
        font-weight: 900;
        font-size: clamp(1.5rem, 4vw, 2.5rem);
        padding: 0.75rem 2rem;
        text-transform: uppercase;
        letter-spacing: -0.03em;
        margin-bottom: 1rem;
      ">
        #{tagName}
      </span>
      <p style="
        color: var(--color-on-surface-variant);
        max-width: 32rem;
        margin: 0 auto;
        font-size: 1rem;
      ">
        Todos los artículos etiquetados con <strong>#{tagName}</strong>
      </p>
    </div>

    {cards.length > 0 ? (
      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
      ">
        {cards.map((card) => (
          <ArticleCard
            title={card.title}
            excerpt={card.excerpt}
            image={card.image}
            imageAlt={card.imageAlt}
            category={card.category}
            href={card.href}
          />
        ))}
      </div>
    ) : (
      <div style="
        text-align: center;
        padding: 3rem 1rem;
        border: 2px dashed var(--color-outline-variant);
        border-radius: 0.5rem;
        color: var(--color-on-surface-variant);
      ">
        <span class="material-symbols-outlined" style="font-size: 3rem; opacity: 0.4;">label</span>
        <p class="font-headline" style="font-weight: 700; margin-top: 1rem;">
          Aún no hay artículos con este tag
        </p>
        <p style="font-size: 0.875rem; margin-top: 0.5rem;">
          Los artículos publicados con este tag aparecerán aquí automáticamente.
        </p>
      </div>
    )}

  </main>
</BaseLayout>
