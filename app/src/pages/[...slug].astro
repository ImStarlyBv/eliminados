---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TrendingSidebar from '@/components/TrendingSidebar.astro';
import { buildJsonLd } from '@/lib/seo';
import { img, srcset } from '@/lib/img';
import { db } from '@/lib/db';
import { articles, authors, categories, articleTags, tags } from '@/db/schema';
import { eq } from 'drizzle-orm';

// Catch-all article route. Serves articles by their full stored slug, which is
// now human-readable: `/<category>/<title-slug>` (e.g.
// /reality/la-isla-de-alofoke-todo-sobre-el-nuevo-reality-de-rd).
// Legacy dated slugs (`/yyyymmdd/...html`) still resolve here too, since the
// lookup is a straight match on articles.slug. More specific routes
// (/tag/*, /autor/*, /[category], /api/*, sitemaps, feeds) take priority over
// this spread route, so it only handles paths nothing else claims.
const { slug } = Astro.params;
const fullSlugPath = slug ?? '';
const siteUrl = import.meta.env.SITE || 'https://eliminados.online';

if (!fullSlugPath) {
  return new Response('Not Found', { status: 404 });
}

const [row] = await db
  .select({
    id: articles.id,
    slug: articles.slug,
    title: articles.title,
    h1: articles.h1,
    metaDescription: articles.metaDescription,
    ogImage: articles.ogImage,
    bodyHtml: articles.bodyHtml,
    publishedAt: articles.publishedAt,
    updatedAt: articles.updatedAt,
    status: articles.status,
    authorName: authors.name,
    authorSlug: authors.slug,
    authorAvatar: authors.avatarUrl,
    categoryName: categories.name,
    categorySlug: categories.slug,
  })
  .from(articles)
  .leftJoin(authors, eq(articles.authorId, authors.id))
  .leftJoin(categories, eq(articles.categoryId, categories.id))
  .where(eq(articles.slug, fullSlugPath))
  .limit(1);

if (!row || row.status !== 'published') {
  return new Response('Not Found', { status: 404 });
}

const tagRows = await db
  .select({ slug: tags.slug, name: tags.name })
  .from(articleTags)
  .innerJoin(tags, eq(articleTags.tagId, tags.id))
  .where(eq(articleTags.articleId, row.id));

const article = {
  title: row.title,
  h1: row.h1,
  metaDescription: row.metaDescription,
  ogImage: row.ogImage || 'https://eliminados.online/og-default.jpg',
  bodyHtml: row.bodyHtml,
  publishedAt: (row.publishedAt ?? row.updatedAt).toISOString(),
  updatedAt: row.updatedAt.toISOString(),
  authorName: row.authorName || 'Redacción ELIMINADOS',
  authorSlug: row.authorSlug || 'redaccion-eliminados',
  authorAvatar:
    row.authorAvatar ||
    'https://images.unsplash.com/photo-1542204165-65bf26472b9b?w=200&h=200&fit=crop',
  category: row.categoryName || 'Noticias',
  categorySlug: row.categorySlug || '',
  tags: tagRows.length
    ? tagRows.map((t) => t.name)
    : ['Eliminados'],
  tagSlugs: tagRows.length
    ? tagRows.map((t) => t.slug)
    : ['eliminados'],
};

const canonicalUrl = `${siteUrl}/${fullSlugPath}`;

const seo = {
  title: article.title,
  description: article.metaDescription,
  canonicalUrl,
  ogImage: article.ogImage,
  type: 'article' as const,
  publishedAt: article.publishedAt,
  updatedAt: article.updatedAt,
  authorName: article.authorName,
  section: article.category,
  tags: article.tags,
};

const jsonLd = buildJsonLd({
  type: 'NewsArticle',
  title: article.title,
  description: article.metaDescription,
  url: canonicalUrl,
  image: article.ogImage,
  publishedAt: article.publishedAt,
  updatedAt: article.updatedAt,
  authorName: article.authorName,
  section: article.category,
  siteName: 'ELIMINADOS',
  siteUrl,
  breadcrumbs: [
    { name: 'Inicio', url: siteUrl },
    { name: article.category, url: `${siteUrl}/${article.categorySlug}/` },
    { name: article.title.slice(0, 40) + '...', url: canonicalUrl },
  ],
});

const trendingItems = [
  { rank: '1', title: 'Yailin La Más Viral sorprende con nueva colaboración', category: 'MÚSICA', href: '#' },
  { rank: '2', title: 'Clasificados a la Serie del Caribe: Lo que debes saber', category: 'DEPORTES', href: '#' },
  { rank: '3', title: 'Premios Soberano 2024: Lista completa de nominados', category: 'FARÁNDULA', href: '#' },
  { rank: '4', title: 'Romeo Santos anuncia última gira con Aventura', category: 'MÚSICA', href: '#' },
  { rank: '5', title: 'Tendencias: Por qué el color rojo domina el género urbano', category: 'VIRAL', href: '#' },
];

const publishDate = new Date(article.publishedAt);
const dateFormatter = new Intl.DateTimeFormat('es-DO', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <main class="container-site" style="
    padding-top: 2rem;
    margin-bottom: 5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  " id="article-layout">

    <!-- Article Column -->
    <article style="max-width: 760px; width: 100%;">

      <!-- Breadcrumb -->
      <nav style="
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        font-size: 0.625rem;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.15em;
        color: var(--color-on-surface-variant);
      ">
        <a href="/" style="text-decoration: none; color: inherit;">INICIO</a>
        <span class="material-symbols-outlined" style="font-size: 10px;">chevron_right</span>
        <a href={`/${article.categorySlug}/`} style="text-decoration: none; color: inherit;">
          {article.category.toUpperCase()}
        </a>
        <span class="material-symbols-outlined" style="font-size: 10px;">chevron_right</span>
        <span style="color: var(--color-on-surface);">ARTÍCULO</span>
      </nav>

      <!-- Kicker -->
      <div style="
        color: var(--color-primary);
        font-family: var(--font-headline);
        font-weight: 900;
        font-size: 0.75rem;
        letter-spacing: 0.2em;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      ">
        <span style="width: 2rem; height: 2px; background: var(--color-primary);"></span>
        {article.category.toUpperCase()} · ELIMINADOS
      </div>

      <!-- Headline (H1) -->
      <h1 class="font-headline" style="
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -0.025em;
        margin-bottom: 1.5rem;
      ">
        {article.h1}
      </h1>

      <!-- Lede -->
      <p style="
        font-size: clamp(1.125rem, 2vw, 1.5rem);
        color: var(--color-on-surface-variant);
        line-height: 1.5;
        margin-bottom: 2rem;
        border-left: 4px solid var(--color-primary-container);
        padding-left: 1.5rem;
        font-style: italic;
      ">
        {article.metaDescription}
      </p>

      <!-- Byline -->
      <div style="
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 1.5rem 0;
        border-top: 1px solid var(--color-surface-container-highest);
        border-bottom: 1px solid var(--color-surface-container-highest);
        margin-bottom: 2rem;
      ">
        <div style="display: flex; align-items: center; gap: 1rem;">
          <div style="
            width: 3rem;
            height: 3rem;
            border-radius: 9999px;
            overflow: hidden;
            background: var(--color-surface-container-high);
          ">
            <img src={article.authorAvatar} alt={article.authorName} style="width: 100%; height: 100%; object-fit: cover;" />
          </div>
          <div>
            <p class="font-headline" style="font-weight: 700; font-size: 0.875rem;">
              <a href={`/autor/${article.authorSlug}/`} style="text-decoration: none; color: inherit;">
                {article.authorName}
              </a>
            </p>
            <div style="
              display: flex;
              align-items: center;
              gap: 0.5rem;
              font-size: 0.6875rem;
              color: var(--color-on-surface-variant);
              text-transform: uppercase;
              letter-spacing: 0.05em;
            ">
              <span style="color: var(--color-primary); font-weight: 700;">{article.category.toUpperCase()}</span>
              <span>•</span>
              <span>{dateFormatter.format(publishDate)}</span>
              <span>•</span>
              <span>5 min lectura</span>
            </div>
          </div>
        </div>

        <!-- Share buttons -->
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <button style="
            width: 2.25rem; height: 2.25rem;
            border-radius: 9999px;
            background: #25D366; color: white;
            border: none; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
          ">
            <span class="material-symbols-outlined" style="font-size: 18px;">chat</span>
          </button>
          <button style="
            width: 2.25rem; height: 2.25rem;
            border-radius: 9999px;
            background: #1877F2; color: white;
            border: none; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
          ">
            <span class="material-symbols-outlined" style="font-size: 18px;">share</span>
          </button>
          <button style="
            width: 2.25rem; height: 2.25rem;
            border-radius: 9999px;
            background: black; color: white;
            border: none; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
          ">
            <span class="material-symbols-outlined" style="font-size: 18px;">link</span>
          </button>
        </div>
      </div>

      <!-- Hero Image -->
      <figure style="margin-bottom: 2.5rem;">
        <div style="
          aspect-ratio: 16/9;
          overflow: hidden;
          border-radius: 2px;
          box-shadow: 0 20px 40px rgba(49, 46, 41, 0.06);
        ">
          <img
            src={img(article.ogImage, 1080)}
            srcset={srcset(article.ogImage, [640, 800, 1080, 1440])}
            sizes="(min-width: 1024px) 800px, 100vw"
            alt={article.title}
            width="1280"
            height="720"
            fetchpriority="high"
            decoding="async"
            style="width: 100%; height: 100%; object-fit: cover;"
          />
        </div>
        <figcaption style="
          margin-top: 0.75rem;
          font-size: 0.875rem;
          color: var(--color-on-surface-variant);
          font-style: italic;
        ">
          Imagen oficial de la presentación de los talentos. (Foto: ELIMINADOS/Cortesía)
        </figcaption>
      </figure>

      <!-- Article Body -->
      <div class="article-prose" set:html={article.bodyHtml} />

      <!-- Tags -->
      <div style="
        margin-top: 3rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      ">
        {article.tags.map((tag, i) => (
          <a href={`/tag/${article.tagSlugs[i]}/`} style="
            background: var(--color-surface-container-highest);
            padding: 0.375rem 1rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--color-on-surface-variant);
            text-decoration: none;
            transition: background 0.2s;
          ">
            #{tag}
          </a>
        ))}
      </div>

      <!-- Author Box -->
      <div style="
        margin-top: 4rem;
        padding: 2rem;
        background: var(--color-surface-container-high);
        border-radius: 1rem;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 2rem;
      ">
        <div style="
          width: 6rem; height: 6rem;
          border-radius: 9999px;
          overflow: hidden;
          flex-shrink: 0;
          box-shadow: 0 0 0 4px white;
        ">
          <img src={article.authorAvatar} alt={article.authorName} style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
        <div style="flex: 1; min-width: 200px;">
          <h5 class="font-headline" style="font-weight: 900; font-size: 1.25rem; margin-bottom: 0.5rem;">
            {article.authorName}
          </h5>
          <p style="
            color: var(--color-on-surface-variant);
            font-size: 0.875rem;
            line-height: 1.6;
          ">
            Cubrimos el latido del entretenimiento en República Dominicana.
            Desde los estudios de radio más influyentes hasta las alfombras rojas internacionales.
          </p>
        </div>
      </div>
    </article>

    <!-- Sidebar -->
    <aside style="display: flex; flex-direction: column; gap: 3rem;">
      <TrendingSidebar items={trendingItems} />

      <!-- Newsletter Box -->
      <div style="
        background: var(--color-secondary-fixed);
        padding: 2rem;
        border-radius: 1.5rem;
        box-shadow: 0 20px 40px rgba(49, 46, 41, 0.06);
        position: relative;
        overflow: hidden;
      ">
        <div style="position: relative; z-index: 1;">
          <h3 class="font-headline" style="font-weight: 900; font-size: 1.5rem; margin-bottom: 0.5rem; color: #5f4200;">
            Chisme diario en tu WhatsApp
          </h3>
          <p style="font-size: 0.875rem; color: rgba(95, 66, 0, 0.8); margin-bottom: 1.5rem;">
            Recibe las exclusivas antes que nadie directamente en tu móvil.
          </p>
          <button style="
            width: 100%;
            background: var(--color-primary);
            color: white;
            font-family: var(--font-headline);
            font-weight: 900;
            padding: 1rem;
            border-radius: 1rem;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            transition: transform 0.15s;
          ">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">bolt</span>
            UNIRME AHORA
          </button>
        </div>
        <span class="material-symbols-outlined" style="
          position: absolute;
          bottom: -2.5rem;
          right: -2.5rem;
          font-size: 180px;
          opacity: 0.1;
          transform: rotate(12deg);
          color: #5f4200;
        ">send</span>
      </div>
    </aside>

  </main>
</BaseLayout>

<style>
  @media (min-width: 1024px) {
    #article-layout {
      grid-template-columns: 1fr 320px !important;
    }
  }
</style>
