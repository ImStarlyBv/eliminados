---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import TrendingSidebar from '@/components/TrendingSidebar.astro';
import { buildJsonLd } from '@/lib/seo';
import { db } from '@/lib/db';
import { DEFAULT_IMAGE, DEFAULT_AVATAR } from '@/lib/defaults';
import { articles, categories, authors, tags, articleTags } from '@/db/schema';
import { eq, desc, and, count } from 'drizzle-orm';

const siteUrl = import.meta.env.SITE || 'http://localhost:4321';

const seo = {
  title: 'ELIMINADOS | El Pulso del Entretenimiento',
  description:
    'Noticias de entretenimiento, farándula, reality shows, música urbana y lo más viral de República Dominicana. ELIMINADOS — tu fuente #1.',
  canonicalUrl: siteUrl,
  type: 'website' as const,
};

const jsonLd = buildJsonLd({
  type: 'WebSite',
  title: seo.title,
  description: seo.description,
  url: siteUrl,
  siteName: 'ELIMINADOS',
  siteUrl,
});

function timeAgoEs(date: Date | null): string {
  if (!date) return '';
  const diff = Date.now() - date.getTime();
  const m = Math.floor(diff / 60000);
  if (m < 1) return 'Hace un instante';
  if (m < 60) return `Hace ${m} minuto${m === 1 ? '' : 's'}`;
  const h = Math.floor(m / 60);
  if (h < 24) return `Hace ${h} hora${h === 1 ? '' : 's'}`;
  const d = Math.floor(h / 24);
  return `Hace ${d} día${d === 1 ? '' : 's'}`;
}

function readTimeEs(words: number): string {
  const mins = Math.max(1, Math.round((words ?? 0) / 200));
  return `${mins} min lectura`;
}

const articleCols = {
  id: articles.id,
  slug: articles.slug,
  title: articles.title,
  metaDescription: articles.metaDescription,
  ogImage: articles.ogImage,
  publishedAt: articles.publishedAt,
  updatedAt: articles.updatedAt,
  wordCount: articles.wordCount,
  categoryName: categories.name,
  categorySlug: categories.slug,
  authorName: authors.name,
  authorAvatar: authors.avatarUrl,
};

const latest = await db
  .select(articleCols)
  .from(articles)
  .leftJoin(categories, eq(articles.categoryId, categories.id))
  .leftJoin(authors, eq(articles.authorId, authors.id))
  .where(eq(articles.status, 'published'))
  .orderBy(desc(articles.publishedAt))
  .limit(20);

const hero = latest[0] ?? null;

const heroArticle = hero
  ? {
      title: hero.title,
      excerpt: hero.metaDescription,
      image: hero.ogImage || DEFAULT_IMAGE,
      imageAlt: hero.title,
      category: (hero.categoryName || 'Noticias').toUpperCase(),
      subcategory: 'ELIMINADOS',
      authorName: hero.authorName || 'Redacción ELIMINADOS',
      authorAvatar: hero.authorAvatar || DEFAULT_AVATAR,
      href: `/${hero.slug}`,
      timeAgo: timeAgoEs(hero.publishedAt ?? hero.updatedAt),
      readTime: readTimeEs(hero.wordCount ?? 0),
    }
  : null;

const trendingItems = latest.slice(1, 6).map((a, i) => ({
  rank: String(i + 1).padStart(2, '0'),
  title: a.title,
  category: (a.categoryName || 'NOTICIAS').toUpperCase(),
  href: `/${a.slug}`,
}));

async function queryByCategory(slug: string, limit: number) {
  return db
    .select(articleCols)
    .from(articles)
    .leftJoin(categories, eq(articles.categoryId, categories.id))
    .leftJoin(authors, eq(articles.authorId, authors.id))
    .where(and(eq(articles.status, 'published'), eq(categories.slug, slug)))
    .orderBy(desc(articles.publishedAt))
    .limit(limit);
}

const farandulaRows = await queryByCategory('farandula', 3);
const farandulaCards = farandulaRows.map((a) => ({
  title: a.title,
  excerpt: a.metaDescription,
  image: a.ogImage || DEFAULT_IMAGE,
  imageAlt: a.title,
  category: 'FARÁNDULA',
  badge: 'FARÁNDULA',
  href: `/${a.slug}`,
}));

const realityRows = await queryByCategory('reality', 4);
const realityCards = realityRows.map((a) => ({
  title: a.title,
  image: a.ogImage || DEFAULT_IMAGE,
  imageAlt: a.title,
  badge: (a.categoryName || 'REALITY').toUpperCase(),
  href: `/${a.slug}`,
}));

const trendingTagRows = await db
  .select({
    slug: tags.slug,
    name: tags.name,
    articleCount: count(articles.id),
  })
  .from(tags)
  .innerJoin(articleTags, eq(articleTags.tagId, tags.id))
  .innerJoin(articles, eq(articleTags.articleId, articles.id))
  .where(eq(articles.status, 'published'))
  .groupBy(tags.id, tags.slug, tags.name)
  .orderBy(desc(count(articles.id)))
  .limit(7);

const trendingTags = trendingTagRows.map((t) => ({
  label: `#${t.name.replace(/\s+/g, '')}`,
  href: `/tag/${t.slug}/`,
}));
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <main class="container-site" style="margin-bottom: 5rem;">

    <!-- ========== HERO SECTION ========== -->
    <section style="
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 4rem;
    " class="hero-grid">
      {heroArticle && (
      <div style="cursor: pointer;">
        <a href={heroArticle.href} style="text-decoration: none; color: inherit; display: block;">
          <div style="
            position: relative;
            overflow: hidden;
            border-radius: 2px;
            margin-bottom: 1.5rem;
            aspect-ratio: 16/9;
          ">
            <img
              src={heroArticle.image}
              alt={heroArticle.imageAlt}
              style="
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
              "
            />
            <div style="
              position: absolute;
              top: 1rem;
              left: 1rem;
              background: var(--color-primary);
              color: white;
              padding: 0.25rem 0.75rem;
              font-size: 0.75rem;
              font-weight: 900;
              text-transform: uppercase;
              letter-spacing: 0.15em;
              display: flex;
              align-items: center;
              gap: 0.5rem;
            ">
              <span style="
                width: 0.5rem;
                height: 0.5rem;
                background: white;
                border-radius: 9999px;
                animation: pulse 2s infinite;
              "></span>
              EN VIVO
            </div>
          </div>

          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <span style="
                background: var(--color-primary);
                color: white;
                font-size: 0.625rem;
                font-weight: 900;
                padding: 0.125rem 0.5rem;
                text-transform: uppercase;
                letter-spacing: 0.15em;
              ">{heroArticle.category}</span>
              <span class="font-headline" style="
                color: var(--color-primary);
                font-weight: 700;
                font-size: 0.625rem;
                text-transform: uppercase;
                letter-spacing: 0.15em;
              ">{heroArticle.subcategory}</span>
            </div>

            <h2 class="font-headline" style="
              font-size: clamp(2rem, 5vw, 3.75rem);
              font-weight: 900;
              text-transform: uppercase;
              line-height: 0.95;
              letter-spacing: -0.05em;
            ">
              {heroArticle.title}
            </h2>

            <p style="
              color: var(--color-on-surface-variant);
              font-size: 1.125rem;
              line-height: 1.6;
              max-width: 48rem;
            ">
              {heroArticle.excerpt}
            </p>

            <div style="display: flex; align-items: center; gap: 1rem; padding-top: 0.5rem;">
              <div style="
                width: 2.5rem;
                height: 2.5rem;
                border-radius: 9999px;
                overflow: hidden;
                background: var(--color-surface-container-highest);
              ">
                <img
                  src={heroArticle.authorAvatar}
                  alt={heroArticle.authorName}
                  style="width: 100%; height: 100%; object-fit: cover;"
                />
              </div>
              <div class="font-headline" style="font-size: 0.75rem; text-transform: uppercase;">
                <p style="font-weight: 900;">Por {heroArticle.authorName}</p>
                <p style="color: var(--color-on-surface-variant);">
                  {heroArticle.timeAgo} • {heroArticle.readTime}
                </p>
              </div>
            </div>
          </div>
        </a>
      </div>
      )}

      <TrendingSidebar items={trendingItems} />
    </section>

    <!-- ========== FARÁNDULA SECTION ========== -->
    <section style="margin-bottom: 5rem;">
      <div style="
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2rem;
      ">
        <h3 class="font-headline" style="
          font-size: clamp(2rem, 4vw, 3rem);
          font-weight: 900;
          text-transform: uppercase;
          letter-spacing: -0.05em;
          color: var(--color-primary);
        ">FARÁNDULA</h3>
        <a href="/farandula/" class="font-headline" style="
          font-weight: 900;
          text-transform: uppercase;
          font-size: 0.75rem;
          letter-spacing: 0.15em;
          color: var(--color-on-surface);
          text-decoration: none;
          border-bottom: 2px solid var(--color-primary);
          padding-bottom: 0.125rem;
        ">Ver todo</a>
      </div>
      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
      ">
        {farandulaCards.map((card) => (
          <ArticleCard
            title={card.title}
            excerpt={card.excerpt}
            image={card.image}
            imageAlt={card.imageAlt}
            category={card.category}
            badge={card.badge}
            href={card.href}
          />
        ))}
      </div>
    </section>

    <!-- ========== NEWSLETTER ========== -->
    <section id="newsletter" style="
      background: var(--color-secondary-fixed);
      padding: 2rem;
      margin-bottom: 5rem;
      border-radius: 2px;
      overflow: hidden;
      position: relative;
    ">
      <span class="material-symbols-outlined" style="
        position: absolute;
        right: 0;
        top: 0;
        font-size: 200px;
        opacity: 0.1;
        pointer-events: none;
        color: #473000;
      ">chat</span>
      <div style="
        position: relative;
        z-index: 1;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
      ">
        <div style="max-width: 28rem;">
          <h3 class="font-headline" style="
            font-size: clamp(1.5rem, 3vw, 2.25rem);
            font-weight: 900;
            text-transform: uppercase;
            line-height: 1;
            letter-spacing: -0.05em;
            margin-bottom: 1rem;
          ">Recibe el chisme del día en tu WhatsApp</h3>
          <p style="font-weight: 700; color: #5f4200;">
            Sé el primero en enterarte de todo lo que pasa. Sin filtros.
          </p>
        </div>
        <div style="
          display: flex;
          flex-wrap: wrap;
          gap: 0.75rem;
          flex: 1;
          min-width: 300px;
        ">
          <input
            type="email"
            placeholder="Tu correo electrónico"
            style="
              flex: 1;
              min-width: 200px;
              background: rgba(255,255,255,0.5);
              border: none;
              border-radius: 0.75rem;
              padding: 1rem 1.5rem;
              font-size: 1rem;
              outline: none;
            "
          />
          <button style="
            background: var(--color-primary);
            color: white;
            font-family: var(--font-headline);
            font-weight: 900;
            padding: 1rem 2rem;
            border-radius: 0.75rem;
            border: none;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            font-size: 0.875rem;
            cursor: pointer;
            transition: background 0.2s;
            white-space: nowrap;
          ">
            UNIRME
          </button>
        </div>
      </div>
    </section>

    <!-- ========== REALITY SECTION ========== -->
    <section style="margin-bottom: 5rem;">
      <div class="newspaper-spine" style="padding-left: 1.5rem; margin-bottom: 2rem;">
        <h3 class="font-headline" style="
          font-size: clamp(2rem, 4vw, 3rem);
          font-weight: 900;
          text-transform: uppercase;
          letter-spacing: -0.05em;
          display: flex;
          align-items: center;
          gap: 1rem;
        ">
          REALITY
          <span style="
            color: var(--color-secondary-fixed);
            font-size: 4.5rem;
            line-height: 1;
          ">.</span>
        </h3>
      </div>
      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.5rem;
      ">
        {realityCards.map((card) => (
          <div style="cursor: pointer;">
            <a href={card.href} style="text-decoration: none; color: inherit; display: block;">
              <div style="position: relative; margin-bottom: 1rem;">
                <img
                  src={card.image}
                  alt={card.imageAlt}
                  loading="lazy"
                  style="
                    width: 100%;
                    height: 16rem;
                    object-fit: cover;
                    border-radius: 2px;
                    transition: filter 0.3s;
                  "
                />
                <div style="
                  position: absolute;
                  bottom: 0.75rem;
                  left: 0.75rem;
                  background: white;
                  padding: 0.25rem 0.5rem;
                  font-size: 0.5rem;
                  font-weight: 900;
                  text-transform: uppercase;
                  letter-spacing: 0.15em;
                  box-shadow: 0 20px 40px rgba(49, 46, 41, 0.06);
                ">
                  {card.badge}
                </div>
              </div>
              <h5 class="font-headline" style="
                font-size: 1.125rem;
                font-weight: 900;
                text-transform: uppercase;
                line-height: 1.2;
                transition: color 0.2s;
              ">
                {card.title}
              </h5>
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- ========== TRENDING TOPICS ========== -->
    {trendingTags.length > 0 && (
    <section style="
      border-top: 1px solid var(--color-surface-container-highest);
      border-bottom: 1px solid var(--color-surface-container-highest);
      padding: 3rem 0;
      margin-bottom: 5rem;
    ">
      <h4 style="
        font-size: 0.75rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        margin-bottom: 1.5rem;
        color: var(--color-on-surface-variant);
        text-align: center;
      ">TEMAS EN TENDENCIA</h4>
      <div style="
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
      ">
        {trendingTags.map((tag) => (
          <a href={tag.href} style="
            background: var(--color-surface-container-highest);
            color: var(--color-on-surface);
            font-weight: 900;
            padding: 0.625rem 1.5rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            text-decoration: none;
            transition: background 0.2s;
          ">
            {tag.label}
          </a>
        ))}
      </div>
    </section>
    )}

  </main>
</BaseLayout>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 7fr 3fr !important;
    }
  }
</style>
