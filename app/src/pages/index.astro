---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <main class="container-site" style="margin-bottom: 5rem;">

    <!-- ========== HERO SECTION ========== -->
    <section style="
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 4rem;
    " class="hero-grid">
      <!-- Major Story -->
      <div style="cursor: pointer;">
        <a href={heroArticle.href} style="text-decoration: none; color: inherit; display: block;">
          <div style="
            position: relative;
            overflow: hidden;
            border-radius: 2px;
            margin-bottom: 1.5rem;
            aspect-ratio: 16/9;
          ">
            <img
              src={heroArticle.image}
              alt={heroArticle.imageAlt}
              style="
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
              "
            />
            <div style="
              position: absolute;
              top: 1rem;
              left: 1rem;
              background: var(--color-primary);
              color: white;
              padding: 0.25rem 0.75rem;
              font-size: 0.75rem;
              font-weight: 900;
              text-transform: uppercase;
              letter-spacing: 0.15em;
              display: flex;
              align-items: center;
              gap: 0.5rem;
            ">
              <span style="
                width: 0.5rem;
                height: 0.5rem;
                background: white;
                border-radius: 9999px;
                animation: pulse 2s infinite;
              "></span>
              EN VIVO
            </div>
          </div>

          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <span style="
                background: var(--color-primary);
                color: white;
                font-size: 0.625rem;
                font-weight: 900;
                padding: 0.125rem 0.5rem;
                text-transform: uppercase;
                letter-spacing: 0.15em;
              ">{heroArticle.category}</span>
              <span class="font-headline" style="
                color: var(--color-primary);
                font-weight: 700;
                font-size: 0.625rem;
                text-transform: uppercase;
                letter-spacing: 0.15em;
              ">{heroArticle.subcategory}</span>
            </div>

            <h2 class="font-headline" style="
              font-size: clamp(2rem, 5vw, 3.75rem);
              font-weight: 900;
              text-transform: uppercase;
              line-height: 0.95;
              letter-spacing: -0.05em;
            ">
              {heroArticle.title.split('Planeta Alofoke 2')[0]}
              <span style="color: var(--color-primary); font-style: italic;">Planeta Alofoke 2</span>
            </h2>

            <p style="
              color: var(--color-on-surface-variant);
              font-size: 1.125rem;
              line-height: 1.6;
              max-width: 48rem;
            ">
              {heroArticle.excerpt}
            </p>

            <div style="display: flex; align-items: center; gap: 1rem; padding-top: 0.5rem;">
              <div style="
                width: 2.5rem;
                height: 2.5rem;
                border-radius: 9999px;
                overflow: hidden;
                background: var(--color-surface-container-highest);
              ">
                <img
                  src={heroArticle.authorAvatar}
                  alt={heroArticle.authorName}
                  style="width: 100%; height: 100%; object-fit: cover;"
                />
              </div>
              <div class="font-headline" style="font-size: 0.75rem; text-transform: uppercase;">
                <p style="font-weight: 900;">Por {heroArticle.authorName}</p>
                <p style="color: var(--color-on-surface-variant);">
                  {heroArticle.timeAgo} • {heroArticle.readTime}
                </p>
              </div>
            </div>
          </div>
        </a>
      </div>

      <!-- Trending Sidebar -->
      <TrendingSidebar items={trendingItems} />
    </section>

    <!-- ========== FARÁNDULA SECTION ========== -->
    <section style="margin-bottom: 5rem;">
      <div style="
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2rem;
      ">
        <h3 class="font-headline" style="
          font-size: clamp(2rem, 4vw, 3rem);
          font-weight: 900;
          text-transform: uppercase;
          letter-spacing: -0.05em;
          color: var(--color-primary);
        ">FARÁNDULA</h3>
        <a href="/farandula/" class="font-headline" style="
          font-weight: 900;
          text-transform: uppercase;
          font-size: 0.75rem;
          letter-spacing: 0.15em;
          color: var(--color-on-surface);
          text-decoration: none;
          border-bottom: 2px solid var(--color-primary);
          padding-bottom: 0.125rem;
        ">Ver todo</a>
      </div>
      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
      ">
        {farandulaCards.map((card) => (
          <ArticleCard
            title={card.title}
            excerpt={card.excerpt}
            image={card.image}
            imageAlt={card.imageAlt}
            category={card.category}
            badge={card.badge}
            href={card.href}
          />
        ))}
      </div>
    </section>

    <!-- ========== NEWSLETTER ========== -->
    <section id="newsletter" style="
      background: var(--color-secondary-fixed);
      padding: 2rem;
      margin-bottom: 5rem;
      border-radius: 2px;
      overflow: hidden;
      position: relative;
    ">
      <span class="material-symbols-outlined" style="
        position: absolute;
        right: 0;
        top: 0;
        font-size: 200px;
        opacity: 0.1;
        pointer-events: none;
        color: #473000;
      ">chat</span>
      <div style="
        position: relative;
        z-index: 1;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
      ">
        <div style="max-width: 28rem;">
          <h3 class="font-headline" style="
            font-size: clamp(1.5rem, 3vw, 2.25rem);
            font-weight: 900;
            text-transform: uppercase;
            line-height: 1;
            letter-spacing: -0.05em;
            margin-bottom: 1rem;
          ">Recibe el chisme del día en tu WhatsApp</h3>
          <p style="font-weight: 700; color: #5f4200;">
            Sé el primero en enterarte de todo lo que pasa. Sin filtros.
          </p>
        </div>
        <div style="
          display: flex;
          flex-wrap: wrap;
          gap: 0.75rem;
          flex: 1;
          min-width: 300px;
        ">
          <input
            type="email"
            placeholder="Tu correo electrónico"
            style="
              flex: 1;
              min-width: 200px;
              background: rgba(255,255,255,0.5);
              border: none;
              border-radius: 0.75rem;
              padding: 1rem 1.5rem;
              font-size: 1rem;
              outline: none;
            "
          />
          <button style="
            background: var(--color-primary);
            color: white;
            font-family: var(--font-headline);
            font-weight: 900;
            padding: 1rem 2rem;
            border-radius: 0.75rem;
            border: none;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            font-size: 0.875rem;
            cursor: pointer;
            transition: background 0.2s;
            white-space: nowrap;
          ">
            UNIRME
          </button>
        </div>
      </div>
    </section>

    <!-- ========== REALITY SECTION ========== -->
    <section style="margin-bottom: 5rem;">
      <div class="newspaper-spine" style="padding-left: 1.5rem; margin-bottom: 2rem;">
        <h3 class="font-headline" style="
          font-size: clamp(2rem, 4vw, 3rem);
          font-weight: 900;
          text-transform: uppercase;
          letter-spacing: -0.05em;
          display: flex;
          align-items: center;
          gap: 1rem;
        ">
          REALITY
          <span style="
            color: var(--color-secondary-fixed);
            font-size: 4.5rem;
            line-height: 1;
          ">.</span>
        </h3>
      </div>
      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 1.5rem;
      ">
        {realityCards.map((card) => (
          <div style="cursor: pointer;">
            <a href={card.href} style="text-decoration: none; color: inherit; display: block;">
              <div style="position: relative; margin-bottom: 1rem;">
                <img
                  src={card.image}
                  alt={card.imageAlt}
                  loading="lazy"
                  style="
                    width: 100%;
                    height: 16rem;
                    object-fit: cover;
                    border-radius: 2px;
                    transition: filter 0.3s;
                  "
                />
                <div style="
                  position: absolute;
                  bottom: 0.75rem;
                  left: 0.75rem;
                  background: white;
                  padding: 0.25rem 0.5rem;
                  font-size: 0.5rem;
                  font-weight: 900;
                  text-transform: uppercase;
                  letter-spacing: 0.15em;
                  box-shadow: 0 20px 40px rgba(49, 46, 41, 0.06);
                ">
                  {card.badge}
                </div>
              </div>
              <h5 class="font-headline" style="
                font-size: 1.125rem;
                font-weight: 900;
                text-transform: uppercase;
                line-height: 1.2;
                transition: color 0.2s;
              ">
                {card.title}
              </h5>
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- ========== TRENDING TOPICS ========== -->
    <section style="
      border-top: 1px solid var(--color-surface-container-highest);
      border-bottom: 1px solid var(--color-surface-container-highest);
      padding: 3rem 0;
      margin-bottom: 5rem;
    ">
      <h4 style="
        font-size: 0.75rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        margin-bottom: 1.5rem;
        color: var(--color-on-surface-variant);
        text-align: center;
      ">TEMAS EN TENDENCIA</h4>
      <div style="
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
      ">
        {trendingTags.map((tag) => (
          <a href={`/tag/${tag.replace('#', '').toLowerCase()}/`} style="
            background: var(--color-surface-container-highest);
            color: var(--color-on-surface);
            font-weight: 900;
            padding: 0.625rem 1.5rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            text-decoration: none;
            transition: background 0.2s;
          ">
            {tag}
          </a>
        ))}
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 7fr 3fr !important;
    }
  }
</style>
