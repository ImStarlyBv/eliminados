---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { buildJsonLd } from '@/lib/seo';
import { db } from '@/lib/db';
import { DEFAULT_IMAGE } from '@/lib/defaults';
import { articles, categories } from '@/db/schema';
import { eq, and, desc } from 'drizzle-orm';

const { category } = Astro.params;
const slug = category || '';

const [cat] = await db
  .select({
    id: categories.id,
    slug: categories.slug,
    name: categories.name,
    description: categories.description,
  })
  .from(categories)
  .where(eq(categories.slug, slug))
  .limit(1);

if (!cat) {
  return new Response('Not Found', { status: 404 });
}

const description =
  cat.description ||
  `Últimas noticias de ${cat.name} en ELIMINADOS. Cobertura del entretenimiento dominicano.`;

const siteUrl = import.meta.env.SITE || 'https://eliminados.online';

const seo = {
  title: `${cat.name} — ELIMINADOS | Noticias de Entretenimiento`,
  description,
  canonicalUrl: `${siteUrl}/${cat.slug}/`,
  type: 'website' as const,
};

const jsonLd = buildJsonLd({
  type: 'WebSite',
  title: seo.title,
  description: seo.description,
  url: seo.canonicalUrl,
  siteName: 'ELIMINADOS',
  siteUrl,
  breadcrumbs: [
    { name: 'Inicio', url: siteUrl },
    { name: cat.name, url: `${siteUrl}/${cat.slug}/` },
  ],
});

const rows = await db
  .select({
    id: articles.id,
    slug: articles.slug,
    title: articles.title,
    metaDescription: articles.metaDescription,
    ogImage: articles.ogImage,
    publishedAt: articles.publishedAt,
  })
  .from(articles)
  .where(and(eq(articles.status, 'published'), eq(articles.categoryId, cat.id)))
  .orderBy(desc(articles.publishedAt))
  .limit(48);

const cards = rows.map((a) => ({
  title: a.title,
  excerpt: a.metaDescription,
  image: a.ogImage || DEFAULT_IMAGE,
  imageAlt: a.title,
  href: `/${a.slug}`,
}));
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <main class="container-site" style="margin-bottom: 5rem; padding-top: 2rem;">

    <!-- Breadcrumb -->
    <nav style="
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
      font-size: 0.625rem;
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--color-on-surface-variant);
    ">
      <a href="/" style="text-decoration: none; color: inherit;">INICIO</a>
      <span class="material-symbols-outlined" style="font-size: 10px;">chevron_right</span>
      <span style="color: var(--color-on-surface);">{cat.name.toUpperCase()}</span>
    </nav>

    <!-- Section Header -->
    <div class="newspaper-spine" style="padding-left: 1.5rem; margin-bottom: 2.5rem;">
      <h1 class="font-headline" style="
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.05em;
        color: var(--color-primary);
        line-height: 1;
      ">
        {cat.name}
      </h1>
      <p style="
        color: var(--color-on-surface-variant);
        font-size: 1.125rem;
        margin-top: 0.75rem;
        max-width: 40rem;
      ">
        {description}
      </p>
    </div>

    {cards.length > 0 ? (
      <div style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 3rem;
      ">
        {cards.map((card) => (
          <ArticleCard
            title={card.title}
            excerpt={card.excerpt}
            image={card.image}
            imageAlt={card.imageAlt}
            category={cat.name.toUpperCase()}
            href={card.href}
          />
        ))}
      </div>
    ) : (
      <div style="
        text-align: center;
        padding: 3rem 1rem;
        border: 2px dashed var(--color-outline-variant);
        border-radius: 0.5rem;
        color: var(--color-on-surface-variant);
      ">
        <span class="material-symbols-outlined" style="font-size: 3rem; opacity: 0.4;">article</span>
        <p class="font-headline" style="font-weight: 700; margin-top: 1rem;">
          Aún no hay artículos en {cat.name}
        </p>
        <p style="font-size: 0.875rem; margin-top: 0.5rem;">
          Los artículos publicados en esta categoría aparecerán aquí automáticamente.
        </p>
      </div>
    )}

  </main>
</BaseLayout>
