---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { buildJsonLd } from '@/lib/seo';

const { slug } = Astro.params;
const siteUrl = import.meta.env.SITE || 'https://eliminados.online';

// Display name from slug
const authorName = (slug || '')
  .replace(/-/g, ' ')
  .replace(/\b\w/g, (c) => c.toUpperCase());

const seo = {
  title: `${authorName} — Autor en ELIMINADOS`,
  description: `Todos los artículos escritos por ${authorName} en ELIMINADOS. Noticias, opiniones y exclusivas.`,
  canonicalUrl: `${siteUrl}/autor/${slug}/`,
  type: 'website' as const,
};

const jsonLd = buildJsonLd({
  type: 'WebSite',
  title: seo.title,
  description: seo.description,
  url: seo.canonicalUrl,
  siteName: 'ELIMINADOS',
  siteUrl,
  breadcrumbs: [
    { name: 'Inicio', url: siteUrl },
    { name: authorName, url: `${siteUrl}/autor/${slug}/` },
  ],
});

// TODO: Query DB for author profile + their articles
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <main class="container-site" style="margin-bottom: 5rem; padding-top: 2rem;">

    <!-- Breadcrumb -->
    <nav style="
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 2rem;
      font-size: 0.625rem;
      text-transform: uppercase;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--color-on-surface-variant);
    ">
      <a href="/" style="text-decoration: none; color: inherit;">INICIO</a>
      <span class="material-symbols-outlined" style="font-size: 10px;">chevron_right</span>
      <span style="color: var(--color-on-surface);">{authorName.toUpperCase()}</span>
    </nav>

    <!-- Author Profile -->
    <div style="
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 3rem 1rem;
      margin-bottom: 3rem;
      background: var(--color-surface-container-low);
      border-radius: 1rem;
    ">
      <!-- Avatar placeholder -->
      <div style="
        width: 6rem;
        height: 6rem;
        border-radius: 9999px;
        background: var(--color-surface-container-highest);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        box-shadow: 0 0 0 4px white;
      ">
        <span class="material-symbols-outlined" style="font-size: 2.5rem; color: var(--color-on-surface-variant);">person</span>
      </div>

      <h1 class="font-headline" style="
        font-size: 2rem;
        font-weight: 900;
        margin-bottom: 0.5rem;
      ">
        {authorName}
      </h1>
      <p style="
        color: var(--color-on-surface-variant);
        max-width: 28rem;
        font-size: 0.875rem;
        line-height: 1.6;
      ">
        Periodista y creador de contenido en ELIMINADOS. Cubriendo el entretenimiento dominicano 24/7.
      </p>
    </div>

    <!-- Articles by author — empty state -->
    <h2 class="font-headline" style="
      font-size: 1.5rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -0.03em;
      margin-bottom: 1.5rem;
    ">
      Artículos de {authorName}
    </h2>

    <div style="
      text-align: center;
      padding: 3rem 1rem;
      border: 2px dashed var(--color-outline-variant);
      border-radius: 0.5rem;
      color: var(--color-on-surface-variant);
    ">
      <span class="material-symbols-outlined" style="font-size: 3rem; opacity: 0.4;">edit_note</span>
      <p class="font-headline" style="font-weight: 700; margin-top: 1rem;">
        Artículos próximamente
      </p>
      <p style="font-size: 0.875rem; margin-top: 0.5rem;">
        Los artículos de este autor aparecerán aquí cuando se publiquen.
      </p>
    </div>

  </main>
</BaseLayout>
